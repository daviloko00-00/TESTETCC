generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id               Int       @id @default(autoincrement())
  nome             String    @db.VarChar(250)
  email            String    @unique @db.VarChar(255)
  senha_hash       String    @db.VarChar(255)
  data_nascimento  DateTime? @db.Date
  ativo            Boolean   @default(true)
  email_verificado Boolean   @default(false)
  ultimo_login     DateTime? @db.Timestamp(0)
  criado_em        DateTime  @default(now()) @db.Timestamp(0)

  dadosCorporais   DadosCorporais?
  usuariosPerfil   UsuariosPerfil[]

  //RELAÇÃO INVERSA
  emailTokens      EmailVerificationToken[]

  @@map("usuarios")
}
model Perfil {
  idPerfil Int    @id @default(autoincrement())
  nome     String @db.VarChar(100)

  usuariosPerfil UsuariosPerfil[]

  @@map("perfil")
}

model UsuariosPerfil {
  idUsuario Int
  idPerfil  Int

  usuario Usuario @relation(fields: [idUsuario], references: [id])
  perfil  Perfil  @relation(fields: [idPerfil], references: [idPerfil])

  @@id([idUsuario, idPerfil])
  @@map("usuarios_perfil")
}

model DadosCorporais {
  idDados       Int      @id @default(autoincrement())
  idUsuario     Int      @unique
  peso_kg       Decimal  @db.Decimal(10, 2)
  altura_cm     Decimal  @db.Decimal(5, 2)
  genero        Genero
  idade         Int
  nivel_atividade NivelAtividade
  data_registro_Inicial DateTime @default(now()) @db.Timestamp(0)
  data_atualizacao_dados DateTime @updatedAt
  historicos HistoricoCorporal[]


  usuario Usuario @relation(fields: [idUsuario], references: [id])
  calculos Calculo[]

  @@map("dados_corporais")
}

model Calculo {
  idCalculo                Int      @id @default(autoincrement())
  idDados                  Int
  imc                      Decimal  @db.Decimal(10, 2)
  tmb                      Decimal  @db.Decimal(10, 2)
  ndc                      Decimal  @db.Decimal(10, 2)
  data_calculo             DateTime @default(now()) @db.Timestamp(0)
  data_atualizacao_calculo DateTime @updatedAt

  dados   DadosCorporais @relation(fields: [idDados], references: [idDados])
  treinos Treino[]

  @@map("calculos")
}

model Treino {
  idTreino     Int      @id @default(autoincrement())
  idCalculo    Int
  objetivo     ObjetivoTreino
  nivel        NivelTreino
  data_criacao DateTime @default(now()) @db.Timestamp(0)

  calculo Calculo @relation(fields: [idCalculo], references: [idCalculo])
  treinoExercicios TreinoExercicio[]

  @@map("treinos")
}

model Exercicio {
  idExercicio  Int     @id @default(autoincrement())
  nome         String  @db.VarChar(150)
  descricao    String? @db.VarChar(255)
  caminho_video String? @db.VarChar(255)

  treinoExercicios TreinoExercicio[]

  @@map("exercicios")
}

model TreinoExercicio {
  idTreino          Int
  idExercicio       Int
  series            Int
  descanso_segundos Int
  repeticoes        Int
  grupo_muscular    String @db.VarChar(250)
  tipo              TipoExercicio

  treino    Treino    @relation(fields: [idTreino], references: [idTreino])
  exercicio Exercicio @relation(fields: [idExercicio], references: [idExercicio])

  @@id([idTreino, idExercicio])
  @@map("treinos_exercicios")
}

model EmailVerificationToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique @db.VarChar(512)
  usuarioId Int
  expira_em DateTime
  criado_em DateTime @default(now()) @db.Timestamp(0)

  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@map("email_verification_tokens")
}

model HistoricoCorporal {
  idHistorico Int @id @default(autoincrement())
  idDados Int

  peso_kg Decimal @db.Decimal(10,2)
  altura_cm Decimal @db.Decimal(5,2)
  genero Genero
  idade Int

  nivel_atividade NivelAtividade

  imc Decimal @db.Decimal(10,2)
  tmb Decimal @db.Decimal(10,2)
  ndc Decimal @db.Decimal(10,2)

  criado_em DateTime @default(now()) @db.Timestamp(0)
  dados DadosCorporais @relation(fields:[idDados], references:[idDados])

  @@index([idDados])
  @@index([criado_em])

  @@map("historico_corporal")
}

//
// ENUMS
//

enum Genero {
  Masculino
  Feminino
  Outro
}

enum NivelAtividade {
  Sedentario
  Leve
  Moderado
  Intenso
  MuitoIntenso
}

enum ObjetivoTreino {
  Hipertrofia
  Emagrecimento
  Resistencia
  Condicionamento
}

enum NivelTreino {
  Iniciante
  Intermediario
  Avancado
}

enum TipoExercicio {
  Forca
  Cardio
  Alongamento
  Mobilidade
}